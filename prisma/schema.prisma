generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Event {
  id           String   @id @default(cuid())
  slug         String   @unique
  title        String
  subtitle     String?
  emoji        String?
  color        String?
  imageUrl     String?
  searchTerms  String[]
  contentTerms String[]  @default([])
  volume       Float?
  liquidity    Float?
  openInterest Float?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  markets    Market[]
  newsItems  NewsItem[]
  xPosts     XPost[]
  videos     Video[]
  tiktoks    TikTok[]
}

model Market {
  id             String   @id @default(cuid())
  eventId        String
  event          Event    @relation(fields: [eventId], references: [id])
  ticker         String
  title          String
  yesPrice       Float
  noPrice        Float
  volume         Float?
  change24h      Float?
  category       String?
  rulesPrimary   String?
  closeTime      DateTime?
  expirationTime DateTime?
  conditionId    String?
  yesTokenId     String?
  noTokenId      String?
  negRisk        Boolean  @default(false)
  tickSize       String   @default("0.01")
  outcomeName    String?
  outcome2Name   String?
  ogImageUrl     String?
  updatedAt      DateTime @updatedAt
}

model NewsItem {
  id        String   @id @default(cuid())
  eventId   String
  event     Event    @relation(fields: [eventId], references: [id])
  title     String
  summary   String
  source    String
  sentiment String
  time      String
  url       String?
  fetchedAt DateTime @default(now())
}

model XPost {
  id        String   @id @default(cuid())
  eventId   String
  event     Event    @relation(fields: [eventId], references: [id])
  name      String
  handle    String
  text      String
  time      String
  likes     String?
  retweets  String?
  tweetId   String?  @unique
  fetchedAt DateTime @default(now())
}

model Video {
  id         String   @id @default(cuid())
  eventId    String
  event      Event    @relation(fields: [eventId], references: [id])
  title      String
  channel    String
  youtubeUrl String
  youtubeId  String?
  duration   String?
  views      String?
  thumbnail  String?
  fetchedAt  DateTime @default(now())
}

model TikTok {
  id        String   @id @default(cuid())
  eventId   String
  event     Event    @relation(fields: [eventId], references: [id])
  videoId   String?  @unique
  username  String
  caption   String
  thumbnail String?
  videoUrl  String
  likes     String?
  views     String?
  fetchedAt DateTime @default(now())
}

model SiteConfig {
  id    String @id @default("singleton")
  key   String @unique
  value String
}

model PriceSnapshot {
  id           String   @id @default(cuid())
  eventId      String
  marketTicker String
  yesPrice     Float
  noPrice      Float
  timestamp    DateTime @default(now())

  @@index([eventId, marketTicker, timestamp])
}

model Position {
  id            String   @id @default(cuid())
  walletAddress String
  marketTicker  String
  marketTitle   String
  eventSlug     String
  eventTitle    String
  side          String
  shares        Float
  avgPrice      Float
  costBasis     Float
  status        String   @default("open")
  orderId       String?
  tokenId       String?
  txSignature   String?
  closeTxSig    String?
  closePrice    Float?
  realizedPnl   Float?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([walletAddress, status])
}

model SynthesisAccount {
  id            String   @id @default(cuid())
  privyUserId   String   @unique
  accountId     String   @unique
  apiKey        String
  walletId      String?
  walletAddress String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model UserProfile {
  id              String   @id @default(cuid())
  privyUserId     String   @unique
  walletAddress   String?
  displayName     String?
  avatarUrl       String?
  twitterHandle   String?
  twitterId       String?
  twitterAvatar   String?
  referralCode    String   @unique
  referredBy      String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([walletAddress])
  @@index([referralCode])
  @@index([referredBy])
}
